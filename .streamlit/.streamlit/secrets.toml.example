# Rename to secrets.toml (local) or paste into Streamlit Cloud -> App ->
# Settings -> Secrets. Generate these values by running generate_token.py
# once on your own machine (see README). Do NOT commit the real secrets.

[google_oauth]
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxx"
refresh_token = "1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
