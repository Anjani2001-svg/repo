# Rename to secrets.toml (local) or paste into Streamlit Cloud → App → Settings → Secrets.
# Values come from the service-account JSON key you download from Google Cloud.
# Do NOT commit the real secrets.toml to git.

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIEv...replace_me...\n-----END PRIVATE KEY-----\n"
client_email = "podcast-uploader@your-project-id.iam.gserviceaccount.com"
client_id = "0000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/podcast-uploader%40your-project-id.iam.gserviceaccount.com"
